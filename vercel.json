{
  "buildCommand": "hugo --minify --gc",
  "outputDirectory": "public",
  "framework": "hugo",
  "build": {
    "env": {
      "HUGO_VERSION": "0.147.0"
    }
  },
  "redirects": [
    { "source": "/spreker/", "destination": "/copilot-inspiratiesessie/", "permanent": true },
    { "source": "/diensten/ai-workshop/", "destination": "/copilot-training/", "permanent": true },
    { "source": "/diensten/eu-ai-act-training/", "destination": "/ai-geletterdheid-training/", "permanent": true },
    { "source": "/diensten/prototype-in-a-day/", "destination": "/diensten/", "permanent": true },
    { "source": "/diensten/procesanalyse/", "destination": "/diensten/", "permanent": true },
    { "source": "/diensten/ai-implementatie/", "destination": "/diensten/", "permanent": true },
    { "source": "/ai-consultant-twente/", "destination": "/copilot-specialist-twente/", "permanent": true },
    { "source": "/geo-check/", "destination": "/", "permanent": true },
    { "source": "/faq/", "destination": "/veelgestelde-vragen/", "permanent": true },
    { "source": "/blog/wie-ik-ben/", "destination": "/over/", "permanent": true },
    { "source": "/blog/ai-agents-voor-het-mkb/", "destination": "/kennisbank/", "permanent": true },
    { "source": "/blog/bedrijfsprocessen-in-kaart-brengen/", "destination": "/kennisbank/", "permanent": true },
    { "source": "/blog/gevonden-worden-in-chatgpt-en-copilot/", "destination": "/kennisbank/", "permanent": true },
    { "source": "/blog/:path*", "destination": "/kennisbank/:path*", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'none'; script-src 'self' 'sha256-oED3ROkK5U8DoFjqdB+BkTDrtQLnigZvTvlrXMXkml8='; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/img/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }]
    },
    {
      "source": "/img/(.*_hu_.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
